# Main program loop
while True:
    display_main_menu()
    choice = input("Enter your choice (1-5): ")

    if choice == '5':
        print("Exiting the application.")
        break

    display_operation_menu()
    operation_choice = input("Enter your operation choice (1-2): ")

    if choice == '1':  # Square
        side = float(input("Enter the side length of the square: "))
        if operation_choice == '1':
            result = calculate_square_area(side)
            print(f"The area of the square is: {result}")
        elif operation_choice == '2':
            result = calculate_square_perimeter(side)
            print(f"The perimeter of the square is: {result}")

    elif choice == '2':  # Circle
        radius = float(input("Enter the radius of the circle: "))
        if operation_choice == '1':
            result = calculate_circle_area(radius)
            print(f"The area of the circle is: {result}")
        elif operation_choice == '2':
            result = calculate_circle_circumference(radius)
            print(f"The circumference of the circle is: {result}")

    elif choice == '3':  # Triangle
        if operation_choice == '1':
            base = float(input("Enter the base of the triangle: "))
            height = float(input("Enter the height of the triangle: "))
            result = calculate_triangle_area(base, height)
            print(f"The area of the triangle is: {result}")
        elif operation_choice == '2':
            side1 = float(input("Enter side 1 of the triangle: "))
            side2 = float(input("Enter side 2 of the triangle: "))
            side3 = float(input("Enter side 3 of the triangle: "))
            result = calculate_triangle_perimeter(side1, side2, side3)
            print(f"The perimeter of the triangle is: {result}")

    elif choice == '4':  # Rectangle
        length = float(input("Enter the length of the rectangle: "))
        width = float(input("Enter the width of the rectangle: "))
        if operation_choice == '1':
            result = calculate_rectangle_area(length, width)
            print(f"The area of the rectangle is: {result}")
        elif operation_choice == '2':
            result = calculate_rectangle_perimeter(length, width)
            print(f"The perimeter of the rectangle is: {result}")

    else:
        print("Invalid choice. Please try again.")